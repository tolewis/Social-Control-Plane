# =============================================================================
# Social Control Plane — example environment
# =============================================================================
# Copy this file to `.env` and fill in the values for your deployment.
# Never commit the real `.env`. All secrets are either AES-GCM encrypted in
# the database or loaded from these env vars at startup.
#
# Required keys are marked "REQUIRED". Everything else is optional per provider
# — you only need the providers you intend to connect.
# =============================================================================

# --- Web ---------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Social Control Plane
NEXT_PUBLIC_API_BASE_URL=http://localhost:4001

# --- API ---------------------------------------------------------------------
APP_PORT=4001
APP_BASE_URL=http://localhost:4001
WEB_BASE_URL=http://localhost:3000

# REQUIRED. Log-in password for the single admin account. Change from the
# default BEFORE exposing SCP to any network. SCP is single-user by design.
ADMIN_PASSWORD=replace-me

# REQUIRED. Used to sign session tokens. Rotate in place if compromised.
SESSION_SECRET=replace-me

# REQUIRED. 32-byte key used for AES-GCM encryption of provider credentials
# stored in the database. Generate with: openssl rand -base64 32
# Rotating this invalidates all stored provider tokens.
ENCRYPTION_KEY=replace-me-with-32-byte-key

# --- Queue / DB --------------------------------------------------------------
# REQUIRED. Postgres + Redis come from the included docker-compose.dev.yml
# for local dev. Replace with your managed services in production.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_control_plane
REDIS_URL=redis://localhost:6379

# --- Ops alerting (optional) -------------------------------------------------
# Discord webhook URL for queue alerts, cron failures, rate limit events.
# Leave blank to disable alerting.
ALERT_WEBHOOK_URL=

# =============================================================================
# Provider credentials
# =============================================================================
# Only fill in the providers you plan to connect. Each provider has its own
# OAuth app that you register at the provider's developer portal.
# See docs/Provider-Setup.md for step-by-step per-provider instructions.
# =============================================================================

# --- LinkedIn ----------------------------------------------------------------
# https://www.linkedin.com/developers/apps → create app → Auth → OAuth 2.0
# Required scopes: openid, profile, w_member_social
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/integrations/linkedin/callback

# --- Meta (Facebook + Instagram) ---------------------------------------------
# https://developers.facebook.com/apps → create app → Facebook Login → Settings
# Required permissions: pages_manage_posts, pages_read_engagement,
# instagram_basic, instagram_content_publish
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/integrations/facebook/callback
INSTAGRAM_REDIRECT_URI=http://localhost:3000/integrations/instagram/callback

# --- X (Twitter) -------------------------------------------------------------
# https://developer.x.com/en/portal/dashboard → create app
# Required scopes: tweet.read, tweet.write, users.read, offline.access,
#                  media.write  ← CRITICAL for image uploads, don't forget this
# API v2 one-shot media upload is used (legacy INIT/APPEND/FINALIZE deprecated
# in 2025). Video / chunked uploads use the new /initialize, /append, /finalize
# dedicated endpoints.
X_API_KEY=
X_API_SECRET=
X_REDIRECT_URI=http://localhost:3000/integrations/x/callback

# --- Reddit (optional, for Reddit community engage) --------------------------
# https://www.reddit.com/prefs/apps → create script app
# Used by scripts/engage-reddit-scraper.py and scripts/reddit-join-subs.py.
# Reddit bans generic User-Agent strings; set REDDIT_USER_AGENT to something
# identifiable per Reddit's API rules: "app-name/version (contact info)".
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=scp-engage/1.0 (your-contact-email@example.com)
# Optional: comma-separated list of subreddit names (no r/ prefix) for
# reddit-join-subs.py. Leave blank to use the script's default list.
REDDIT_TARGET_SUBS=

# --- Discord bot delivery (optional) -----------------------------------------
# If you want digests / alerts / scheduled-run output delivered via Discord.
# Create bots at https://discord.com/developers/applications → Bot → Token
#
# Primary Discord bot token (required if you use ANY Discord delivery).
DISCORD_BOT_TOKEN=
# Per-agent bot tokens for multi-agent setups. Add one env var per agent
# following the pattern DISCORD_BOT_TOKEN_<AGENT_ID_UPPER>. The FB engage
# runner expects an agent-specific bot for its delivery channel; rename the
# var if your agent uses a different id. Safe to leave blank for single-bot
# deployments.
# Example: DISCORD_BOT_TOKEN_MY_BOT=
# META_PAID_THREAD_ID — Discord thread id where the FB engage runner and
# paid-media jobs post. Leave blank to disable thread-targeted delivery.
META_PAID_THREAD_ID=

# --- Engage caps (FB community engagement runner) ----------------------------
# Soft cap ("capMode=soft") = guidance only; runner posts up to TARGET_PENDING.
# Hard cap = runner blocks when today >= dailyCap.
# ENGAGE_DAILY_CAP      per-day ceiling across all pages for this connection
# ENGAGE_PER_PAGE_CAP   per-page-per-day ceiling
ENGAGE_DAILY_CAP=25
ENGAGE_PER_PAGE_CAP=3

# --- FB engage runner overrides (optional) -----------------------------------
# Tune only if you understand the runner's internals. See
# scripts/engage-scraper.py and the fb_engage_review_runner companion.
# OLLAMA_URL       override for tailored-comment LLM backend (defaults to
#                  http://192.168.0.160:11434/api/generate — only meaningful
#                  if you actually have Ollama on the LAN; otherwise the
#                  runner uses `codex exec` via the Codex CLI instead)
# OLLAMA_MODEL     Ollama model name
# CODEX_BIN        path to `codex` CLI binary (default: codex)
# CODEX_MODEL      Codex model for comment generation (default: gpt-5.4)
# SCRAPER_TIMEOUT_SECONDS  subprocess cap for engage-scraper.py (default 1800)
OLLAMA_URL=
OLLAMA_MODEL=
CODEX_BIN=
CODEX_MODEL=
SCRAPER_TIMEOUT_SECONDS=

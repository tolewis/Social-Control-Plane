generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PublishJobStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  RECONCILING
  CANCELED
}

model Operator {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String
  role      String   @default("human") // "human" | "agent"
  password  String?  // bcrypt hash, nullable for API-key-only agents
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  apiKeys   ApiKey[]
}

model ApiKey {
  id         String    @id @default(cuid())
  operatorId String
  operator   Operator  @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String
  prefix     String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([keyHash])
}

model SocialConnection {
  id               String   @id @default(cuid())
  provider         String
  displayName      String
  accountRef       String
  encryptedToken   String
  encryptedRefresh String?
  scopes           String[]
  expiresAt        DateTime?
  status           String   @default("connected")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  drafts           Draft[]
  jobs             PublishJob[]
}

model Draft {
  id             String   @id @default(cuid())
  connectionId   String
  publishMode    String
  status         String   @default("draft")
  title          String?
  content        String   @db.Text
  mediaJson      Json?
  scheduledFor   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  connection     SocialConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  jobs           PublishJob[]
  visualSpecs    VisualSpec[]

  @@index([connectionId])
  @@index([status])
  @@index([createdAt])
}

model VisualSpec {
  id               String   @id @default(cuid())
  draftId          String
  draft            Draft    @relation(fields: [draftId], references: [id], onDelete: Cascade)
  templateName     String
  templateData     Json
  generatedMediaId String?
  validated        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([draftId])
}

model PublishJob {
  id               String   @id @default(cuid())
  draftId          String
  connectionId     String
  status           PublishJobStatus @default(PENDING)
  idempotencyKey   String   @unique
  receiptJson      Json?
  errorMessage     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  draft            Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  connection       SocialConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([draftId])
  @@index([connectionId])
  @@index([status])
}

model AuditEvent {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
}

model Media {
  id          String   @id @default(cuid())
  filename    String
  originalName String
  mimeType    String
  sizeBytes   Int
  storagePath String
  width       Int?
  height      Int?
  alt         String?
  createdAt   DateTime @default(now())
}

model IdempotencyKey {
  id          String   @id @default(cuid())
  key         String   @unique
  scope       String
  requestHash String
  responseJson Json?
  createdAt   DateTime @default(now())
}

model ProviderConfig {
  id                    String   @id @default(cuid())
  provider              String   @unique
  encryptedClientId     String
  encryptedClientSecret String
  redirectUri           String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Community Engagement — commenting on fishing communities (FB + Reddit)
// ---------------------------------------------------------------------------

model EngagePage {
  id          String   @id @default(cuid())
  fbPageId    String   @unique          // FB numeric ID or Reddit subreddit name (e.g. "r/Fishing")
  platform    String   @default("facebook") // "facebook" | "reddit"
  name        String
  category    String   @default("community") // community, brand, charter, media, subreddit
  enabled     Boolean  @default(true)
  lastScanned DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       EngagePost[]

  @@index([platform])
}

model EngagePost {
  id            String          @id @default(cuid())
  engagePageId  String
  engagePage    EngagePage      @relation(fields: [engagePageId], references: [id])
  fbPostId      String          @unique
  postUrl       String?
  postText      String?         @db.Text
  authorName    String?
  postedAt      DateTime?
  likeCount     Int?
  commentCount  Int?
  shareCount    Int?
  discoveredAt  DateTime        @default(now())
  commented     Boolean         @default(false)
  skippedReason String?
  comments      EngageComment[]

  @@index([engagePageId])
  @@index([discoveredAt])
}

model EngageComment {
  id            String     @id @default(cuid())
  engagePostId  String
  engagePost    EngagePost @relation(fields: [engagePostId], references: [id])
  connectionId  String
  commentText   String     @db.Text
  kbSources     String[]
  slopScore     Int        @default(0)
  status        String     @default("pending_review")
  // pending_review | approved | rejected | posted | failed | expired
  reviewedBy    String?
  reviewedAt    DateTime?
  rejectionNote String?
  receiptJson   Json?
  fbCommentId   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status])
  @@index([engagePostId])
  @@index([createdAt])
}

model StudioBatch {
  id        String   @id @default(cuid())
  status    String   @default("pending") // pending, rendering, complete, failed, expired
  config    Json     // base RenderConfig
  options   Json     // BatchOptions (count, variation rules)
  results   Json?    // array of { index, previewPath, critiqueScore, approved, mediaId?, draftIds? }
  count     Int      @default(25)
  rendered  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime // createdAt + 24h for cleanup
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PublishJobStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  RECONCILING
  CANCELED
}

model Operator {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String
  role      String   @default("human") // "human" | "agent"
  password  String?  // bcrypt hash, nullable for API-key-only agents
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  apiKeys   ApiKey[]
}

model ApiKey {
  id         String    @id @default(cuid())
  operatorId String
  operator   Operator  @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String
  prefix     String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([keyHash])
}

model SocialConnection {
  id               String   @id @default(cuid())
  provider         String
  displayName      String
  accountRef       String
  encryptedToken   String
  encryptedRefresh String?
  scopes           String[]
  expiresAt        DateTime?
  status           String   @default("connected")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  drafts           Draft[]
  jobs             PublishJob[]
}

model Draft {
  id             String   @id @default(cuid())
  connectionId   String
  publishMode    String
  status         String   @default("draft")
  title          String?
  content        String   @db.Text
  mediaJson      Json?
  scheduledFor   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  connection     SocialConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  jobs           PublishJob[]
  visualSpecs    VisualSpec[]

  @@index([connectionId])
  @@index([status])
  @@index([createdAt])
}

model VisualSpec {
  id               String   @id @default(cuid())
  draftId          String
  draft            Draft    @relation(fields: [draftId], references: [id], onDelete: Cascade)
  templateName     String
  templateData     Json
  generatedMediaId String?
  validated        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([draftId])
}

model PublishJob {
  id               String   @id @default(cuid())
  draftId          String
  connectionId     String
  status           PublishJobStatus @default(PENDING)
  idempotencyKey   String   @unique
  receiptJson      Json?
  errorMessage     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  draft            Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  connection       SocialConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([draftId])
  @@index([connectionId])
  @@index([status])
}

model AuditEvent {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
}

model Media {
  id          String   @id @default(cuid())
  filename    String
  originalName String
  mimeType    String
  sizeBytes   Int
  storagePath String
  width       Int?
  height      Int?
  alt         String?
  createdAt   DateTime @default(now())
}

model IdempotencyKey {
  id          String   @id @default(cuid())
  key         String   @unique
  scope       String
  requestHash String
  responseJson Json?
  createdAt   DateTime @default(now())
}

model ProviderConfig {
  id                    String   @id @default(cuid())
  provider              String   @unique
  encryptedClientId     String
  encryptedClientSecret String
  redirectUri           String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Community Engagement — commenting on fishing communities (FB + Reddit)
// ---------------------------------------------------------------------------

model EngagePage {
  id           String    @id @default(cuid())
  fbPageId     String    @unique          // FB numeric ID or Reddit subreddit name (e.g. "r/Fishing")
  platform     String    @default("facebook") // "facebook" | "reddit"
  name         String
  category     String    @default("community") // community, brand, charter, media, subreddit
  enabled      Boolean   @default(true)
  lastScanned  DateTime?
  // Canonical Graph API page id learned by the worker resolver. Often
  // differs from `fbPageId` (which is the legacy user-migration ID the
  // mbasic scraper captures). Populated on first successful comment.
  realFbPageId String?
  // Set whenever the worker successfully posts a comment targeting a
  // post on this page. Drives rotation: runners prefer pages with
  // null or oldest lastPostedAt so Bill doesn't hammer the same 8
  // pages every run.
  lastPostedAt DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  posts        EngagePost[]

  @@index([platform])
  @@index([lastPostedAt])
}

model EngagePost {
  id                String          @id @default(cuid())
  engagePageId      String
  engagePage        EngagePage      @relation(fields: [engagePageId], references: [id])
  fbPostId          String          @unique
  // Graph-confirmed canonical post id. Set once by the worker resolver on
  // the first comment attempt; subsequent attempts read this and skip the
  // resolver GET. Often differs from `fbPostId` because the scraper stores
  // the mbasic legacy owner id, not the canonical page id Graph wants.
  canonicalFbPostId String?
  postUrl           String?
  postText          String?         @db.Text
  authorName        String?
  postedAt          DateTime?
  likeCount         Int?
  commentCount      Int?
  shareCount        Int?
  discoveredAt      DateTime        @default(now())
  commented         Boolean         @default(false)
  skippedReason     String?
  comments          EngageComment[]

  @@index([engagePageId])
  @@index([discoveredAt])
}

// Per-platform engage settings. Singleton rows keyed by platform name —
// the runners (fb_engage_review_runner, reddit_engage_review_runner) read
// their own row at startup to decide whether to run at all (`enabled`),
// how many comments to attempt (`perRunCap`), and what cadence to report
// in the digest (`runsPerDay` — advisory, the actual systemd timer lives
// in ~/.config/systemd/user/ and is the source of truth for schedule).
// Writable via /engage/config API so Tim and Bill can toggle from the
// /engage UI or from a Discord command without touching systemd.
model EngageConfig {
  id         String   @id @default(cuid())
  platform   String   @unique                 // "facebook" | "reddit"
  enabled    Boolean  @default(true)          // kill switch — false pauses the runner
  perRunCap  Int      @default(8)             // comments to attempt per timer fire
  runsPerDay Int      @default(4)             // advisory: how many times the timer fires daily
  updatedAt  DateTime @updatedAt
  updatedBy  String?
  createdAt  DateTime @default(now())
}

model EngageComment {
  id            String     @id @default(cuid())
  engagePostId  String
  engagePost    EngagePost @relation(fields: [engagePostId], references: [id])
  connectionId  String
  commentText   String     @db.Text
  kbSources     String[]
  slopScore     Int        @default(0)
  status        String     @default("pending_review")
  // pending_review | needs_attention | approved | rejected | posted | failed | expired
  reviewedBy    String?
  reviewedAt    DateTime?
  rejectionNote String?
  receiptJson   Json?
  fbCommentId   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status])
  @@index([engagePostId])
  @@index([createdAt])
}

model StudioBatch {
  id        String   @id @default(cuid())
  status    String   @default("pending") // pending, rendering, complete, failed, expired
  config    Json     // base RenderConfig
  options   Json     // BatchOptions (count, variation rules)
  results   Json?    // array of { index, previewPath, critiqueScore, approved, mediaId?, draftIds? }
  count     Int      @default(25)
  rendered  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime // createdAt + 24h for cleanup
}

{
  "name": "@scp/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ../../prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@prisma/client": "6.4.1",
    "bullmq": "^5.34.8",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "zod": "^3.24.2",
    "@scp/shared": "workspace:*",
    "@scp/providers": "workspace:*"
  },
  "devDependencies": {
    "prisma": "6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
